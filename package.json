{
  "name": "@keogh/menu",
  "version": "0.1.0",
  "description": "A searchable terminal command launcher for macOS.",
  "type": "module",
  "bin": {
    "menu": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "dev": "tsx src/cli.tsx",
    "install-cli": "npm install && npm run build && npm link",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.8.0",
    "fuzzysort": "^3.1.0",
    "ink": "^5.2.1",
    "node-pty": "1.2.0-beta.14",
    "react": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "@types/react": "^18.3.23",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
